{
  "name": "@gyga-browser/webmcp-ai",
  "version": "0.2.1",
  "description": "Provider-neutral CLI and JSON-stdio tool protocol for invoking local AI CLIs.",
  "license": "MIT",
  "author": "uyencss",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uyencss/webmcp-ai.git"
  },
  "homepage": "https://github.com/uyencss/webmcp-ai#readme",
  "bugs": {
    "url": "https://github.com/uyencss/webmcp-ai/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "webmcp-ai": "bin/webmcp-ai.mjs"
  },
  "exports": {
    ".": "./src/client.mjs",
    "./bin": "./bin/webmcp-ai.mjs",
    "./providers": "./src/providers/index.mjs",
    "./protocol": "./src/protocol.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "bin/",
    "scripts/",
    "skills/",
    "src/",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:coverage": "node --experimental-test-coverage --test-coverage-include='src/**/*.mjs' --test-coverage-include='bin/*.mjs' --test-coverage-lines=80 --test-coverage-functions=80 --test-coverage-branches=80 --test tests/*.test.mjs",
    "install:agent": "node scripts/install-agent.mjs all",
    "install:codex": "node scripts/install-agent.mjs codex",
    "install:gemini": "node scripts/install-agent.mjs gemini",
    "install:claude": "node scripts/install-agent.mjs claude",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run test:coverage"
  },
  "engines": {
    "node": ">=18"
  }
}
